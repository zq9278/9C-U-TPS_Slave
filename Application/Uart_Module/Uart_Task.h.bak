// 创建者: zq, 日期: 25-9-11

#ifndef UART_TASK_H
#define UART_TASK_H

#include "ADC_Current.h"
#include "stream_buffer.h"

// 就绪标志：0=A 缓冲准备好；1=B 缓冲准备好
extern volatile uint8_t ready_flag;

// FreeRTOS 信号量（采样同步）
extern SemaphoreHandle_t adc_sem;

// ADC1 Ping-Pong 缓冲
extern uint32_t adc1_bufA[ADC1_CH_NUM * ADC_BATCH];
extern uint32_t adc1_bufB[ADC1_CH_NUM * ADC_BATCH];

// 采样数据流出缓存
extern StreamBufferHandle_t adc_stream_buffer;

#endif // UART_TASK_H

